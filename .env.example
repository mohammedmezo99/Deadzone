# Database Configuration (Neon/Postgres)
# Use the pooled connection URL (?sslmode=require)
DATABASE_URL="postgres://user:password@ep-rest-of-url.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection for migrations (if needed)
DIRECT_URL="postgres://user:password@ep-rest-of-url.region.aws.neon.tech/neondb"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Storage
NEXT_PUBLIC_STORAGE_URL="your-storage-url"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
